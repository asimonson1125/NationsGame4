# Flask
FLASK_ENV=production
SECRET_KEY=change-me

# PostgreSQL (Docker Compose / production)
POSTGRES_USER=ng4
POSTGRES_PASSWORD=change-me
POSTGRES_DB=ng4

# Database URL (constructed from above for Docker; override for external DB)
DATABASE_URL=postgresql://ng4:change-me@db:5432/ng4

# Cache
CACHE_TYPE=RedisCache
REDIS_URL=redis://localhost:6379/0

# SMTP / Email
MAIL_SERVER=smtp.example.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your-smtp-username
MAIL_PASSWORD=your-smtp-password
MAIL_DEFAULT_SENDER="Nations Engine <noreply@example.com>"

# Gunicorn
WEB_CONCURRENCY=4

# External proxy (NPM / Nginx Proxy Manager)
# Set to expose the app on a host port for NPM to forward to.
# Default: 127.0.0.1:8001 — only reachable locally.
# Leave unset to use the default, or override: APP_PORT=0.0.0.0:8001
APP_PORT=127.0.0.1:8001
